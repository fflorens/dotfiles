#!/usr/bin/env lua

-- Determine the configuration directory
local config_dir = os.getenv("HOME") .. "/.config/sketchybar"

-- Prepend the configuration directory to the module search paths
package.path = config_dir .. "/?.lua;" .. config_dir .. "/?/init.lua;" .. package.path
local sbar_lua = os.getenv("HOME") .. "/.local/share/sketchybar_lua"
package.cpath = config_dir .. "/?.so;" .. sbar_lua .. "/?.so;" .. package.cpath

-- Build helpers if needed (first install only)
require("helpers")

-- Wait for the sketchybar mach service to be ready before loading the config.
-- Without this, lua races ahead of the daemon startup and silently fails to connect.
local retries = 0
while os.execute("sketchybar --query bar >/dev/null 2>&1") ~= 0 and retries < 20 do
    os.execute("sleep 0.25")
    retries = retries + 1
end

require("init")
